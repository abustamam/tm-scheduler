{
  "name": "tm-scheduler",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "NITRO_PRESET=node-server vite build && bun run build:migrate",
    "build:migrate": "bun build scripts/migrate.ts --target node --outfile .output/migrate.mjs",
    "start": "node .output/migrate.mjs && node .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env.local src/db/seed.ts",
    "import-members": "bun run scripts/import-members.ts",
    "import-agendas": "bun run scripts/import-agendas.ts",
    "seed:pathways-catalog": "bun run scripts/seed-pathways-catalog.ts",
    "resolve:speech-projects": "bun run scripts/resolve-speech-projects.ts",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "ext:dev": "cd extension && bun run dev",
    "ext:build": "cd extension && bun run build",
    "ext:test": "cd extension && bun run test",
    "ext:build:firefox": "cd extension && bunx wxt build -b firefox",
    "ext:zip:firefox": "cd extension && bunx wxt zip -b firefox"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "nitro": "npm:nitro-nightly@3.0.1-20260626-071224-83acc441",
    "pg": "^8.16.3",
    "pptxgenjs": "^4.0.1",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
