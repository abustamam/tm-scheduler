#!/usr/bin/env bash
# CodeLedger vendored CLI wrapper — auto-generated by CodeLedger
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SELF_PATH="$SCRIPT_DIR/codeledger"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
if [ -f "$REPO_ROOT/packages/cli/dist/index.js" ] && [ -f "$REPO_ROOT/scripts/build-standalone.mjs" ]; then
  exec node "$REPO_ROOT/packages/cli/dist/index.js" "$@"
fi
GLOBAL_CMD="$(command -v codeledger 2>/dev/null || true)"
if [ -n "$GLOBAL_CMD" ] && [ "$GLOBAL_CMD" = "$SELF_PATH" ]; then
  GLOBAL_CMD=""
fi

if [ -n "$GLOBAL_CMD" ]; then
  GLOBAL_VER="$(CODELEDGER_GLOBAL_VERSION_PROBE=1 "$GLOBAL_CMD" --version 2>/dev/null | sed -n 's/^codeledger v//p' | tail -1)"
  LOCAL_VER="$(CODELEDGER_DELEGATED=1 node "$SCRIPT_DIR/codeledger-standalone.cjs" --version 2>/dev/null | sed -n 's/^codeledger v//p' | tail -1)"
  if [ -n "$GLOBAL_VER" ] && [ -n "$LOCAL_VER" ]; then
    WINNER="$(node -e 'const parse=v=>(v||"0").split(".").map(n=>parseInt(n,10)||0); const a=parse(process.argv[1]); const b=parse(process.argv[2]); const len=Math.max(a.length,b.length); let out="eq"; for (let i=0;i<len;i++){ const av=a[i]||0; const bv=b[i]||0; if (av>bv){out="a"; break;} if (av<bv){out="b"; break;} } process.stdout.write(out);' "$GLOBAL_VER" "$LOCAL_VER" 2>/dev/null || true)"
    if [ "$WINNER" = "eq" ]; then
      exec "$GLOBAL_CMD" "$@"
    elif [ "$WINNER" = "a" ]; then
      # Global is newer — exec it immediately and copy its standalone CJS to the local vendor dir in background.
      # Direct file copy (not "codeledger vendor") avoids the vendor command preferring the stale local copy.
      if [ -z "$CODELEDGER_QUIET" ] && [ -z "$CODELEDGER_SKIP_AMBIENT_ACTIVATION" ]; then
        echo "⬆️  Auto-upgrading: global codeledger v$GLOBAL_VER > repo-local v$LOCAL_VER" >&2
      fi
      # Try npm package dirs, home vendored runtime, then the release-cache path.
      GLOBAL_DIR_REAL="$(dirname "$(realpath "$GLOBAL_CMD" 2>/dev/null || echo "$GLOBAL_CMD")")"
      GLOBAL_STANDALONE=""
      for _cand in "$GLOBAL_DIR_REAL/codeledger-standalone.cjs" "$(dirname "$GLOBAL_CMD")/codeledger-standalone.cjs" "$HOME/.codeledger/bin/codeledger-standalone.cjs" "${CODELEDGER_CACHE_DIR:-$HOME/.cache/codeledger/bin}/codeledger-standalone-v${GLOBAL_VER}.cjs"; do
        if [ -f "$_cand" ]; then
          GLOBAL_STANDALONE="$_cand"
          break
        fi
      done
      if [ -n "$GLOBAL_STANDALONE" ]; then
        # Atomic copy via temp file to avoid a partial-write race with concurrent readers.
        _tmp="$SCRIPT_DIR/codeledger-standalone.cjs.$$"
        (cp "$GLOBAL_STANDALONE" "$_tmp" 2>/dev/null && mv -f "$_tmp" "$SCRIPT_DIR/codeledger-standalone.cjs" 2>/dev/null || rm -f "$_tmp" 2>/dev/null &)
      fi
      exec "$GLOBAL_CMD" "$@"
    else
      if [ -z "$CODELEDGER_QUIET" ] && [ -z "$CODELEDGER_SKIP_AMBIENT_ACTIVATION" ]; then
        echo "⚠️  Repo-local codeledger v$LOCAL_VER is newer than global v$GLOBAL_VER — using repo-local." >&2
        echo "   Run \`codeledger upgrade --global\` to update the global install." >&2
      fi
    fi
  else
    if [ -z "$CODELEDGER_QUIET" ] && [ -z "$CODELEDGER_SKIP_AMBIENT_ACTIVATION" ]; then
      echo "⚠️  Could not compare global vs repo-local version — using repo-local standalone." >&2
    fi
  fi
fi

exec node "$SCRIPT_DIR/codeledger-standalone.cjs" "$@"
